# Google Sheets (optional). Prefer Sheets API for speed — see docs/GOOGLE_SHEETS.md.

# Fast path (service account) — share the sheet with the SA email as Editor.
GOOGLE_SHEETS_SPREADSHEET_ID=1rhm8XpNQIIIrtaBwIB6tTSrOwbP3zScRpPm-DGeni_U
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Or paste the whole downloaded JSON key as one line:
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Slow fallback (Apps Script Web App). Used only if API env above is unset.
SHEETS_WEBHOOK_URL=
SHEETS_SECRET=

# HMAC secret for signed session cookies (required for multi-instance / Vercel).
# Use a long random string, e.g. `openssl rand -hex 32`.
# Falls back to SHEETS_SECRET if unset.
SESSION_SECRET=

# Optional. Protects /api/sheets/warmup when set (Vercel Cron sends the bearer).
CRON_SECRET=
