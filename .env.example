# Google Sheets mirror (optional). Leave unset to keep the app fully in-memory.
# See docs/GOOGLE_SHEETS.md for the 5-minute setup.
SHEETS_WEBHOOK_URL=
SHEETS_SECRET=

# HMAC secret for signed session cookies (required for multi-instance / Vercel).
# Use a long random string, e.g. `openssl rand -hex 32`.
# Falls back to SHEETS_SECRET if unset.
SESSION_SECRET=
